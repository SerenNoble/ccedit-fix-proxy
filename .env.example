# ccedit-fix-proxy 配置
# 复制为 .env 后填入实际值: cp .env.example .env

# 上游 API 地址 (必填)
EDIT_FIX_UPSTREAM=https://open.bigmodel.cn/api/anthropic

# 代理监听端口
EDIT_FIX_PORT=8080

# API Key (Claude Code 启动时也需要设 ANTHROPIC_API_KEY)
# ANTHROPIC_API_KEY=your-api-key-here

# 测试模式：强制所有 Edit 的 old_string/new_string 为固定值 (默认关闭)
# EDIT_FIX_TEST=true
# EDIT_FIX_TEST_OLD='old_flag = "HELLO change"'
# EDIT_FIX_TEST_NEW="hello mkp"
